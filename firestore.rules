rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Materiais ──────────────────────────────────────────────────────
    // Alunas (não autenticadas): leitura livre
    // Admin (autenticado):       leitura + escrita completa
    match /materiais/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Dúvidas ────────────────────────────────────────────────────────
    match /duvidas/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Bloqueia qualquer outra coleção por padrão ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
