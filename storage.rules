rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Uploads de Materiais ───────────────────────────────────────────
    // Qualquer usuário pode visualizar imagens (necessário para as alunas)
    // Apenas admin autenticado pode fazer upload ou excluir
    match /materiais/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Bloqueia qualquer outro caminho por padrão ────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
